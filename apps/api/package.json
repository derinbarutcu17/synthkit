{
  "name": "@synthkit/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "synthkit-api": "bin/synthkit-api.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --conditions=source --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@synthkit/core": "workspace:*",
    "@synthkit/domain": "workspace:*",
    "@synthkit/shared": "workspace:*",
    "@synthkit/providers": "workspace:*",
    "fastify": "^5.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
