    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@synthkit/domain": "workspace:*",
    "@synthkit/providers": "workspace:*",
    "@synthkit/shared": "workspace:*",
    "@synthkit/storage": "workspace:*",
    "pdf-parse": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "vitest": "^3.2.4",
    "typescript": "^5.9.3"
  }
}
